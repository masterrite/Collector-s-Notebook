// ui/main.slint — Collector v5
// Unicode chrome (×, ✓, ←, ↑, ↓, →) + Segoe UI Emoji for emoji-displaying elements

import { ScrollView } from "std-widgets.slint";
import "../assets/fonts/NotoSansCJK-Regular-subset.otf";
import "../assets/fonts/NotoSansCJK-Bold-subset.otf";

// ─── Data Structures ──────────────────────────────────────────────────────────

export struct CollectionData {
    id: string,
    name: string,
    icon: string,
    item-count: int,
    row-match: bool,
}

export struct ItemData {
    id: string,
    name: string,
    short-desc: string,
    has-photo: bool,
    thumbnail: image,
    collection-id: string,
}

export struct FieldData {
    id: string,
    label: string,
    value: string,
}

export struct PhotoData {
    index: int,
    is-main: bool,
    thumbnail: image,
}

export struct TemplateData {
    id: string,
    name: string,
    field-labels: string,
}

export struct CheckedItem {
    checked: bool,
}

// ─── Theme Global ─────────────────────────────────────────────────────────────

export global Theme {
    in-out property <bool>   dark-mode:      true;
    in-out property <length> ui-font-size:   15px;
    // Font for user-entered content (CJK-capable). UI chrome stays system default.
    out property <string> content-font: "Noto Sans CJK SC";
    in-out property <color>  bg-base:        #0f1117;
    in-out property <color>  bg-panel:       #161b24;
    in-out property <color>  bg-surface:     #1e2535;
    in-out property <color>  bg-elevated:    #252d40;
    in-out property <color>  bg-card:        #1a2130;
    in-out property <color>  bg-card-hover:  #212a3e;
    in-out property <color>  bg-selected:    #1d3557;
    in-out property <color>  bg-input:       #0f1117;
    in-out property <color>  accent:         #4f8ef7;
    in-out property <color>  accent-dim:     #2a4f96;
    in-out property <color>  accent-glow:    #4f8ef730;
    in-out property <color>  accent-text:    #7eb3ff;
    in-out property <color>  text-primary:   #e8edf5;
    in-out property <color>  text-secondary: #8896b0;
    in-out property <color>  text-muted:     #4a5568;
    in-out property <color>  border:         #252d40;
    in-out property <color>  border-accent:  #4f8ef750;
    in-out property <color>  danger-bg:      #3d1515;
    in-out property <color>  danger-text:    #f87171;
}

// ─── Drag Handle ──────────────────────────────────────────────────────────────

component DragHandle {
    callback drag(length);
    width: 6px;
    drag-touch := TouchArea {
        width: 6px; mouse-cursor: col-resize;
        property <length> start-x;
        pointer-event(e) => {
            if e.button == PointerEventButton.left && e.kind == PointerEventKind.down {
                start-x = self.mouse-x;
            }
        }
        moved => {
            if self.pressed {
                root.drag(self.mouse-x - self.start-x);
                self.start-x = self.mouse-x;
            }
        }
    }
    Rectangle {
        width: 2px; x: 2px; height: parent.height;
        background: drag-touch.has-hover || drag-touch.pressed ? Theme.accent : Theme.border;
        animate background { duration: 100ms; }
    }
}

// ─── Section Label ────────────────────────────────────────────────────────────

component SectionLabel {
    in property <string> text;
    height: 22px;
    Text {
        text: root.text;
        width: 100%;
        font-size: max(9px, Theme.ui-font-size - 4px);
        letter-spacing: 1.5px; color: Theme.text-muted;
        font-weight: 600; vertical-alignment: center;
        horizontal-alignment: center;
    }
}

// ─── Small button used everywhere ─────────────────────────────────────────────

component SmallBtn {
    in property <string> label;
    in property <bool>   danger: false;
    in property <bool>   active: false;
    in property <length> btn-width: 30px;
    callback clicked;
    width: btn-width; height: 30px;
    t := TouchArea { clicked => { root.clicked(); } }
    Rectangle {
        border-radius: 6px;
        background: root.active ? Theme.accent
                  : (t.has-hover ? (root.danger ? Theme.danger-bg : Theme.bg-elevated) : transparent);
        animate background { duration: 120ms; }
        Text {
            text: root.label;
            font-family: "Segoe UI Emoji";
            font-size: Theme.ui-font-size - 2px;
            width: 100%; height: 100%;
            color: root.active ? #fff
                 : (t.has-hover ? (root.danger ? Theme.danger-text : Theme.text-primary)
                                : Theme.text-secondary);
            horizontal-alignment: center; vertical-alignment: center;
        }
    }
}

// ─── Checkbox ────────────────────────────────────────────────────────────────

component Checkbox {
    in property <bool> checked;
    callback toggled;
    width: 18px; height: 18px;
    t := TouchArea { clicked => { root.toggled(); } }
    Rectangle {
        border-radius: 4px; border-width: 1px;
        border-color: root.checked ? Theme.accent : Theme.border;
        background: root.checked ? Theme.accent : transparent;
        animate background { duration: 100ms; }
        if root.checked: Rectangle {
            width: 8px; height: 8px; border-radius: 4px;
            background: #fff;
            x: (parent.width  - self.width)  / 2;
            y: (parent.height - self.height) / 2;
        }
    }
}

// ─── Color Swatch ─────────────────────────────────────────────────────────────

component ColorSwatch {
    in property <color> swatch-color;
    in property <bool>  selected;
    callback clicked;
    width: 28px; height: 28px;
    t := TouchArea { clicked => { root.clicked(); } }
    Rectangle {
        border-radius: 6px; background: root.swatch-color;
        border-width: root.selected ? 2px : (t.has-hover ? 1px : 0px);
        border-color: root.selected ? Theme.text-primary : #ffffff60;
        animate border-width { duration: 100ms; }
        if root.selected: Rectangle {
            width: 8px; height: 8px; border-radius: 4px; background: #fff;
            x: (parent.width  - self.width)  / 2;
            y: (parent.height - self.height) / 2;
        }
    }
}

// ─── Close Button ────────────────────────────────────────────────────────────

component CloseBtn {
    callback clicked;
    width: 28px; height: 28px;
    t := TouchArea { clicked => { root.clicked(); } }
    Rectangle {
        border-radius: 6px;
        background: t.has-hover ? Theme.bg-elevated : transparent;
        animate background { duration: 100ms; }
        Text {
            text: "×"; font-size: 15px; font-weight: 400;
            color: t.has-hover ? Theme.text-primary : Theme.text-secondary;
            horizontal-alignment: center; vertical-alignment: center;
        }
    }
}

// ─── Context Menu ─────────────────────────────────────────────────────────────

component ContextMenu {
    in property <length> menu-x;
    in property <length> menu-y;
    in property <string> label-primary;   // e.g. "Duplicate item"
    in property <string> label-danger;    // e.g. "Delete item"
    in property <bool>   show-rename: false;
    callback rename-action();
    callback primary-action();
    callback danger-action();
    callback dismissed();

    property <length> menu-h: root.show-rename ? 120px : 84px;

    // Scrim — consume clicks outside
    TouchArea {
        width: parent.width; height: parent.height;
        clicked => { root.dismissed(); }
    }

    Rectangle {
        x: min(root.menu-x, parent.width  - 170px);
        y: min(root.menu-y, parent.height - root.menu-h);
        width: 170px; height: root.menu-h;
        border-radius: 8px;
        background: Theme.bg-elevated;
        border-width: 1px; border-color: Theme.border;
        drop-shadow-blur: 16px; drop-shadow-color: #00000050;

        VerticalLayout {
            padding: 4px; spacing: 0px;

            if root.show-rename: rn-t := TouchArea {
                height: 36px;
                clicked => { root.rename-action(); }
                Rectangle {
                    border-radius: 6px;
                    background: rn-t.has-hover ? Theme.bg-surface : transparent;
                    Text {
                        text: "Rename"; font-size: Theme.ui-font-size - 2px;
                        color: Theme.text-primary;
                        vertical-alignment: center; x: 12px;
                    }
                }
            }

            p-t := TouchArea {
                height: 36px;
                clicked => { root.primary-action(); }
                Rectangle {
                    border-radius: 6px;
                    background: p-t.has-hover ? Theme.bg-surface : transparent;
                    Text {
                        text: root.label-primary; font-size: Theme.ui-font-size - 2px;
                        color: Theme.text-primary;
                        vertical-alignment: center; x: 12px;
                    }
                }
            }
            d-t := TouchArea {
                height: 36px;
                clicked => { root.danger-action(); }
                Rectangle {
                    border-radius: 6px;
                    background: d-t.has-hover ? Theme.danger-bg : transparent;
                    Text {
                        text: root.label-danger; font-size: Theme.ui-font-size - 2px;
                        color: d-t.has-hover ? Theme.danger-text : Theme.text-primary;
                        vertical-alignment: center; x: 12px;
                    }
                }
            }
        }
    }
}

// ─── Icon Picker Button ───────────────────────────────────────────────────────

component IconPickerBtn {
    in property <string> icon;
    callback picked(string);
    width: 40px; height: 40px;
    btn-t := TouchArea {
        clicked => { root.picked(root.icon); }
        Rectangle {
            border-radius: 6px;
            background: btn-t.has-hover ? Theme.bg-surface : transparent;
            Text {
                text: root.icon; font-family: "Segoe UI Emoji"; font-size: 20px;
                width: parent.width; height: parent.height;
                horizontal-alignment: center; vertical-alignment: center;
            }
        }
    }
}

// ─── Icon Picker ──────────────────────────────────────────────────────────────

component IconPicker {
    callback picked(string);
    callback close();

    // Scrim
    TouchArea {
        width: parent.width; height: parent.height;
        clicked => { root.close(); }
    }

    // Modal — consumes clicks so they don't reach scrim
    Rectangle {
        x: (parent.width  - 360px) / 2;
        y: (parent.height - 320px) / 2;
        width: 360px; height: 320px;
        border-radius: 12px; background: Theme.bg-panel;
        border-width: 1px; border-color: Theme.border;
        drop-shadow-blur: 24px; drop-shadow-color: #00000050;

        // Consume clicks inside modal so scrim doesn't fire
        TouchArea { width: parent.width; height: parent.height; }

        VerticalLayout {
            padding: 16px; spacing: 10px;

            HorizontalLayout {
                alignment: space-between; height: 28px;
                Text { text: "Choose icon"; font-size: Theme.ui-font-size; font-weight: 700; color: Theme.text-primary; vertical-alignment: center; }
                CloseBtn { clicked => { root.close(); } }
            }

            ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 4px; padding: 4px;
                    HorizontalLayout { spacing: 4px;
                        for ico in ["📁","🎧","🖊","📷","🎮","📚","⌚","💍"]: IconPickerBtn { icon: ico; picked(i) => { root.picked(i); } }
                    }
                    HorizontalLayout { spacing: 4px;
                        for ico in ["🎸","🎨","🏆","🎯","🔬","🚀","🌿","🍷"]: IconPickerBtn { icon: ico; picked(i) => { root.picked(i); } }
                    }
                    HorizontalLayout { spacing: 4px;
                        for ico in ["⚽","🎲","💎","🖥","📻","🎺","🎻","🏺"]: IconPickerBtn { icon: ico; picked(i) => { root.picked(i); } }
                    }
                    HorizontalLayout { spacing: 4px;
                        for ico in ["💰","🔑","🔧","🔭","🎁","🚲","🌱","🐾"]: IconPickerBtn { icon: ico; picked(i) => { root.picked(i); } }
                    }
                    HorizontalLayout { spacing: 4px;
                        for ico in ["🦋","🌊","🏠","🎭","🍵","🌍","🐶","📦"]: IconPickerBtn { icon: ico; picked(i) => { root.picked(i); } }
                    }
                }
            }
        }
    }
}

// ─── Template Picker ──────────────────────────────────────────────────────────

component TemplatePicker {
    in property <[TemplateData]> templates;
    callback apply(string);
    callback delete-tmpl(string);
    callback rename-tmpl(string, string);
    callback close();

    // Scrim
    TouchArea {
        width: parent.width; height: parent.height;
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width  - 360px) / 2;
        y: (parent.height - 380px) / 2;
        width: 360px; height: 380px;
        border-radius: 12px; background: Theme.bg-panel;
        border-width: 1px; border-color: Theme.border;
        drop-shadow-blur: 24px; drop-shadow-color: #00000050;

        // Consume inner clicks
        TouchArea { width: parent.width; height: parent.height; }

        VerticalLayout {
            padding: 16px; spacing: 10px;

            HorizontalLayout {
                alignment: space-between; height: 28px;
                Text { text: "Field Templates"; font-size: Theme.ui-font-size; font-weight: 700; color: Theme.text-primary; vertical-alignment: center; }
                CloseBtn { clicked => { root.close(); } }
            }

            if root.templates.length == 0: Rectangle {
                height: 70px;
                Text {
                    text: "No templates yet. Use 'Save as template'\non an item with custom fields.";
                    font-size: Theme.ui-font-size - 2px; color: Theme.text-muted;
                    horizontal-alignment: center; vertical-alignment: center;
                    wrap: word-wrap; width: parent.width;
                }
            }

            ScrollView {
                vertical-stretch: 1;
                VerticalLayout {
                    spacing: 6px;
                    for tmpl in root.templates: VerticalLayout {
                        spacing: 4px;

                        HorizontalLayout {
                            spacing: 6px; height: 54px; alignment: center;

                            apply-t := TouchArea {
                                horizontal-stretch: 1;
                                clicked => { root.apply(tmpl.id); }
                                Rectangle {
                                    border-radius: 8px;
                                    background: apply-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                                    border-width: 1px; border-color: Theme.border;
                                    VerticalLayout {
                                        padding: 8px; spacing: 2px;
                                        Text { text: tmpl.name; font-size: Theme.ui-font-size - 1px; font-weight: 600; font-family: Theme.content-font; color: Theme.text-primary; overflow: elide; }
                                        Text { text: tmpl.field-labels; font-size: Theme.ui-font-size - 3px; font-family: Theme.content-font; color: Theme.text-muted; overflow: elide; }
                                    }
                                }
                            }

                            del-tmpl-t := TouchArea {
                                width: 28px; height: 28px;
                                clicked => { root.delete-tmpl(tmpl.id); }
                                Rectangle {
                                    border-radius: 6px;
                                    background: del-tmpl-t.has-hover ? Theme.danger-bg : transparent;
                                    Text { text: "×"; font-size: 13px; font-weight: 400; color: Theme.danger-text; horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                        }

                        // Inline rename row
                        rename-t := TouchArea {
                            height: 28px;
                            property <bool> renaming: false;
                            property <string> rename-val;
                            clicked => {
                                if !self.renaming {
                                    self.rename-val = tmpl.name;
                                    self.renaming = true;
                                }
                            }

                            if !self.renaming: Rectangle {
                                border-radius: 4px;
                                background: rename-t.has-hover ? Theme.bg-surface : transparent;
                                Text {
                                    text: "Rename..."; font-size: Theme.ui-font-size - 3px;
                                    color: Theme.text-muted; x: 8px; vertical-alignment: center;
                                }
                            }
                            if self.renaming: Rectangle {
                                border-radius: 4px; background: Theme.bg-input;
                                border-width: 1px; border-color: Theme.accent-dim;
                                HorizontalLayout {
                                    padding: 4px; spacing: 4px;
                                    TextInput {
                                        text <=> rename-t.rename-val;
                                        font-size: Theme.ui-font-size - 2px; color: Theme.text-primary;
                                        vertical-alignment: center; horizontal-stretch: 1;
                                        accepted => {
                                            root.rename-tmpl(tmpl.id, rename-t.rename-val);
                                            rename-t.renaming = false;
                                        }
                                    }
                                    ok-t := TouchArea {
                                        width: 28px; clicked => {
                                            root.rename-tmpl(tmpl.id, rename-t.rename-val);
                                            rename-t.renaming = false;
                                        }
                                        Rectangle {
                                            border-radius: 4px;
                                            background: ok-t.has-hover ? Theme.accent : Theme.bg-elevated;
                                            Text { text: "OK"; font-size: 10px; font-weight: 700; color: #fff; horizontal-alignment: center; vertical-alignment: center; }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// ─── Settings Panel ───────────────────────────────────────────────────────────

component SettingsPanel {
    callback close();
    callback toggle-dark-mode();
    callback set-accent(color);
    callback set-font-size(length);
    callback export-data();
    callback import-data();
    callback open-data-folder();

    property <[color]> accents: [
        #4f8ef7, #7c5cbf, #2ecc71, #e67e22,
        #e74c3c, #1abc9c, #e91e8c, #f0c040,
    ];

    // Scrim — only covers area outside the modal
    TouchArea {
        width: parent.width; height: parent.height;
        clicked => { root.close(); }
    }

    // Modal card — must consume clicks to prevent scrim from firing
    Rectangle {
        x: (parent.width  - 420px) / 2;
        y: (parent.height - 540px) / 2;
        width: 420px; height: 540px;
        border-radius: 14px; background: Theme.bg-panel;
        border-width: 1px; border-color: Theme.border;
        drop-shadow-blur: 32px; drop-shadow-color: #00000060; drop-shadow-offset-y: 8px;

        // Inner TouchArea prevents click-through to scrim
        TouchArea { width: parent.width; height: parent.height; }

        VerticalLayout {
            padding: 24px; spacing: 0px;

            HorizontalLayout {
                alignment: space-between; height: 36px;
                Text { text: "Settings"; font-size: Theme.ui-font-size + 1px; font-weight: 700; color: Theme.text-primary; vertical-alignment: center; }
                CloseBtn { clicked => { root.close(); } }
            }

            Rectangle { height: 18px; }
            SectionLabel { text: "APPEARANCE"; }
            Rectangle { height: 10px; }

            // Dark / Light toggle
            HorizontalLayout {
                alignment: space-between; height: 36px;
                Text { text: Theme.dark-mode ? "Dark mode" : "Light mode"; font-size: Theme.ui-font-size - 2px; color: Theme.text-secondary; vertical-alignment: center; }
                toggle-t := TouchArea {
                    width: 48px; height: 26px;
                    clicked => { root.toggle-dark-mode(); }
                    Rectangle {
                        border-radius: 13px;
                        background: Theme.dark-mode ? Theme.accent : Theme.bg-elevated;
                        border-width: 1px; border-color: Theme.border;
                        animate background { duration: 200ms; }
                        Rectangle {
                            width: 18px; height: 18px; border-radius: 9px; background: #fff;
                            x: Theme.dark-mode ? 26px : 4px; y: 3px;
                            animate x { duration: 200ms; easing: ease-in-out; }
                        }
                    }
                }
            }

            Rectangle { height: 4px; }

            // Accent colour
            HorizontalLayout {
                alignment: space-between; height: 36px;
                Text { text: "Accent colour"; font-size: Theme.ui-font-size - 2px; color: Theme.text-secondary; vertical-alignment: center; }
                HorizontalLayout {
                    spacing: 5px; alignment: center;
                    for c in root.accents: ColorSwatch {
                        swatch-color: c; selected: Theme.accent == c;
                        clicked => { root.set-accent(c); }
                    }
                }
            }

            Rectangle { height: 4px; }

            // Font size
            HorizontalLayout {
                alignment: space-between; height: 36px;
                Text { text: "Font size"; font-size: Theme.ui-font-size - 2px; color: Theme.text-secondary; vertical-alignment: center; }
                HorizontalLayout {
                    spacing: 4px; alignment: center;
                    minus-t := TouchArea {
                        width: 28px; height: 28px;
                        clicked => { root.set-font-size(max(11px, Theme.ui-font-size - 1px)); }
                        Rectangle {
                            border-radius: 6px;
                            background: minus-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                            border-width: 1px; border-color: Theme.border;
                            Text { text: "-"; font-size: 16px; font-weight: 700; color: Theme.text-primary; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                    Rectangle {
                        width: 36px; height: 28px; border-radius: 6px;
                        background: Theme.bg-surface; border-width: 1px; border-color: Theme.border;
                        Text { text: Theme.ui-font-size / 1px; font-size: 12px; color: Theme.text-primary; horizontal-alignment: center; vertical-alignment: center; }
                    }
                    plus-t := TouchArea {
                        width: 28px; height: 28px;
                        clicked => { root.set-font-size(min(22px, Theme.ui-font-size + 1px)); }
                        Rectangle {
                            border-radius: 6px;
                            background: plus-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                            border-width: 1px; border-color: Theme.border;
                            Text { text: "+"; font-size: 16px; font-weight: 700; color: Theme.text-primary; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }
            }

            Rectangle { height: 16px; }
            Rectangle { height: 1px; background: Theme.border; }
            Rectangle { height: 16px; }
            SectionLabel { text: "DATA"; }
            Rectangle { height: 10px; }

            // Export
            export-t := TouchArea {
                height: 44px; clicked => { root.export-data(); }
                Rectangle {
                    border-radius: 8px;
                    background: export-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                    border-width: 1px; border-color: Theme.border;
                    animate background { duration: 120ms; }
                    HorizontalLayout {
                        padding-left: 14px; spacing: 10px; alignment: center;
                        VerticalLayout {
                            alignment: center;
                            Text { text: "Export collection data"; font-size: Theme.ui-font-size - 2px; color: Theme.text-primary; }
                            Text { text: "Save a JSON backup"; font-size: Theme.ui-font-size - 4px; color: Theme.text-muted; }
                        }
                    }
                }
            }

            Rectangle { height: 6px; }

            // Import
            import-t := TouchArea {
                height: 44px; clicked => { root.import-data(); }
                Rectangle {
                    border-radius: 8px;
                    background: import-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                    border-width: 1px; border-color: Theme.border;
                    animate background { duration: 120ms; }
                    HorizontalLayout {
                        padding-left: 14px; spacing: 10px; alignment: center;
                        VerticalLayout {
                            alignment: center;
                            Text { text: "Import collection data"; font-size: Theme.ui-font-size - 2px; color: Theme.text-primary; }
                            Text { text: "Merge from JSON file"; font-size: Theme.ui-font-size - 4px; color: Theme.text-muted; }
                        }
                    }
                }
            }

            Rectangle { height: 6px; }

            // Open data folder
            folder-t := TouchArea {
                height: 44px; clicked => { root.open-data-folder(); }
                Rectangle {
                    border-radius: 8px;
                    background: folder-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                    border-width: 1px; border-color: Theme.border;
                    animate background { duration: 120ms; }
                    HorizontalLayout {
                        padding-left: 14px; spacing: 10px; alignment: center;
                        VerticalLayout {
                            alignment: center;
                            Text { text: "Open data folder"; font-size: Theme.ui-font-size - 2px; color: Theme.text-primary; }
                            Text { text: "AppData/Local/collector"; font-size: Theme.ui-font-size - 4px; color: Theme.text-muted; }
                        }
                    }
                }
            }

            Rectangle { height: 10px; }
        }
    }
}

// ─── Photo Lightbox ───────────────────────────────────────────────────────────

component PhotoLightbox {
    in property <image> photo;
    in property <int> index;
    in property <int> count;
    callback close();
    callback prev();
    callback next();

    forward-focus: lb-keys;
    lb-keys := FocusScope {
        init => { self.focus(); }
        key-pressed(e) => {
            if (e.text == Key.Escape) { root.close(); accept }
            else if (e.text == Key.LeftArrow) { root.zoom = 1.0; root.pan-x = 0px; root.pan-y = 0px; root.prev(); accept }
            else if (e.text == Key.RightArrow) { root.zoom = 1.0; root.pan-x = 0px; root.pan-y = 0px; root.next(); accept }
            else { reject }
        }
    }

    TouchArea {
        width: parent.width; height: parent.height;
        clicked => { root.close(); }
        Rectangle {
            background: #000000cc;
            width: parent.width; height: parent.height;
        }
    }

    // Zoom / pan state. pan-x/y are offsets from the centered position.
    property <float> zoom: 1.0;
    property <length> pan-x: 0px;
    property <length> pan-y: 0px;
    property <length> base-w: root.width * 0.8;
    property <length> base-h: root.height * 0.8;
    property <float> new-zoom;

    // Max pan = half the overflow beyond the viewport (0 when not zoomed).
    function clamp-pan() {
        root.pan-x = clamp(root.pan-x, -(root.base-w * (root.zoom - 1)) / 2, (root.base-w * (root.zoom - 1)) / 2);
        root.pan-y = clamp(root.pan-y, -(root.base-h * (root.zoom - 1)) / 2, (root.base-h * (root.zoom - 1)) / 2);
    }

    // Zoom toward cursor. mx/my are cursor coords within the image area (0..base-w).
    // The vector from area-center to cursor, minus current pan, is the image point
    // under the cursor; scaling must keep it fixed, so pan shifts by that vector * (ratio-1).
    function do-zoom(zoom-in: bool, mx: length, my: length) {
        root.new-zoom = clamp(root.zoom * (zoom-in ? 1.15 : 0.87), 1.0, 5.0);
        root.pan-x = root.pan-x - ((mx - root.base-w / 2) - root.pan-x) * (root.new-zoom / root.zoom - 1);
        root.pan-y = root.pan-y - ((my - root.base-h / 2) - root.pan-y) * (root.new-zoom / root.zoom - 1);
        root.zoom = root.new-zoom;
        root.clamp-pan();
    }

    img-area := TouchArea {
        x: root.width * 0.1; y: root.height * 0.1;
        width: root.base-w; height: root.base-h;
        mouse-cursor: root.zoom > 1.0 ? grab : default;

        property <length> press-pan-x;
        property <length> press-pan-y;

        scroll-event(e) => {
            root.do-zoom(e.delta-y > 0, self.mouse-x, self.mouse-y);
            accept
        }
        moved => {
            if (root.zoom > 1.0) {
                root.pan-x = self.press-pan-x + (self.mouse-x - self.pressed-x);
                root.pan-y = self.press-pan-y + (self.mouse-y - self.pressed-y);
                root.clamp-pan();
            }
        }
        pointer-event(e) => {
            if (e.kind == PointerEventKind.down) {
                self.press-pan-x = root.pan-x;
                self.press-pan-y = root.pan-y;
            }
        }

        Image {
            source: root.photo;
            // Centered, then offset by pan. Width = area * zoom.
            x: (parent.width - self.width) / 2 + root.pan-x;
            y: (parent.height - self.height) / 2 + root.pan-y;
            width: parent.width * root.zoom;
            height: parent.height * root.zoom;
            image-fit: contain;
        }
    }

    // Previous button (only if more than one photo)
    if root.count > 1: prev-t := TouchArea {
        x: 16px; y: parent.height / 2 - 28px;
        width: 44px; height: 56px;
        clicked => { root.zoom = 1.0; root.pan-x = 0px; root.pan-y = 0px; root.prev(); }
        Rectangle {
            border-radius: 8px;
            background: prev-t.has-hover ? #ffffff35 : #ffffff18;
            Text { text: "‹"; font-size: 30px; color: #fff; horizontal-alignment: center; vertical-alignment: center; }
        }
    }
    // Next button
    if root.count > 1: next-t := TouchArea {
        x: parent.width - 60px; y: parent.height / 2 - 28px;
        width: 44px; height: 56px;
        clicked => { root.zoom = 1.0; root.pan-x = 0px; root.pan-y = 0px; root.next(); }
        Rectangle {
            border-radius: 8px;
            background: next-t.has-hover ? #ffffff35 : #ffffff18;
            Text { text: "›"; font-size: 30px; color: #fff; horizontal-alignment: center; vertical-alignment: center; }
        }
    }

    // Counter "2 / 5"
    if root.count > 1: Rectangle {
        x: parent.width / 2 - 30px; y: parent.height - 44px;
        width: 60px; height: 26px;
        border-radius: 13px; background: #00000088;
        Text { text: (root.index + 1) + " / " + root.count; font-size: 13px; color: #fff;
               horizontal-alignment: center; vertical-alignment: center; }
    }

    // Close hint
    close-t := TouchArea {
        x: parent.width - 60px; y: 12px;
        width: 48px; height: 28px;
        clicked => { root.close(); }
        Rectangle {
            border-radius: 6px; background: close-t.has-hover ? #ffffff35 : #ffffff20;
            Text { text: "×"; font-size: 15px; color: #fff; horizontal-alignment: center; vertical-alignment: center; }
        }
    }
}

// ─── Collection Row ───────────────────────────────────────────────────────────

component CollectionRow {
    in property <CollectionData> data;
    in property <bool> selected;
    in property <bool> checked: false;
    in property <bool> multi-select-mode: false;
    in property <bool> row-visible: true;
    callback clicked(bool, bool);  // ctrl, shift
    callback double-clicked;
    callback icon-clicked;
    callback check-toggled;
    callback right-clicked(length, length);

    // Captured from the most recent pointer-down
    property <bool> last-ctrl: false;
    property <bool> last-shift: false;

    visible: root.row-visible;
    height: root.row-visible ? 52px : 0px;
    t := TouchArea {
        clicked => { root.clicked(root.last-ctrl, root.last-shift); }
        double-clicked => { root.double-clicked(); }
        pointer-event(e) => {
            if e.kind == PointerEventKind.down {
                root.last-ctrl = e.modifiers.control;
                root.last-shift = e.modifiers.shift;
            }
            if e.button == PointerEventButton.right && e.kind == PointerEventKind.up {
                root.right-clicked(
                    t.absolute-position.x + self.mouse-x,
                    t.absolute-position.y + self.mouse-y
                );
            }
        }
    }

    Rectangle {
        border-radius: 8px;
        background: root.selected ? Theme.bg-selected : (t.has-hover ? Theme.bg-surface : transparent);
        border-width: root.selected ? 1px : 0px;
        border-color: Theme.border-accent;
        animate background { duration: 140ms; }

        // Left accent bar
        if root.selected: Rectangle {
            x: 0px; y: 10px;
            width: 3px; height: parent.height - 20px;
            border-radius: 2px; background: Theme.accent;
        }

        HorizontalLayout {
            padding-left: 10px; padding-right: 10px; spacing: 8px; alignment: start;

            if root.multi-select-mode: Rectangle {
                width: 18px;
                VerticalLayout {
                    alignment: center;
                    Checkbox {
                        checked: root.checked;
                        toggled => { root.check-toggled(); }
                    }
                }
            }

            // Icon badge — click to change icon (vertically centered)
            VerticalLayout {
                alignment: center;
                icon-t := TouchArea {
                    width: 30px; height: 30px;
                    clicked => { root.icon-clicked(); }
                    Rectangle {
                        border-radius: 8px;
                        background: root.selected ? Theme.accent-dim : Theme.bg-elevated;
                        border-width: icon-t.has-hover ? 1px : 0px;
                        border-color: Theme.accent;
                        animate background { duration: 140ms; }
                        Text {
                            text: root.data.icon;
                            font-family: "Segoe UI Emoji";
                            font-size: Theme.ui-font-size + 2px;
                            width: parent.width; height: parent.height;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }
                }
            }

            VerticalLayout {
                alignment: center; spacing: 2px; horizontal-stretch: 1;
                Text {
                    text: root.data.name;
                    font-size: Theme.ui-font-size;
                    font-family: Theme.content-font;
                    overflow: elide;
                    font-weight: root.selected ? 600 : 400;
                    color: root.selected ? Theme.text-primary : Theme.text-secondary;
                }
                Text {
                    text: root.data.item-count + " items";
                    font-size: max(10px, Theme.ui-font-size - 3px);
                    color: Theme.text-muted;
                }
            }
        }
    }
}

// ─── Item Card ────────────────────────────────────────────────────────────────

component ItemCard {
    in property <ItemData> data;
    in property <bool> selected;
    in property <bool> checked: false;
    in property <bool> multi-select-mode: false;
    callback clicked(bool, bool);  // ctrl, shift
    callback double-clicked;
    callback check-toggled;
    callback right-clicked(length, length);

    property <bool> last-ctrl: false;
    property <bool> last-shift: false;

    height: 80px;
    t := TouchArea {
        clicked => { root.clicked(root.last-ctrl, root.last-shift); }
        double-clicked => { root.double-clicked(); }
        pointer-event(e) => {
            if e.kind == PointerEventKind.down {
                root.last-ctrl = e.modifiers.control;
                root.last-shift = e.modifiers.shift;
            }
            if e.button == PointerEventButton.right && e.kind == PointerEventKind.up {
                root.right-clicked(
                    t.absolute-position.x + self.mouse-x,
                    t.absolute-position.y + self.mouse-y
                );
            }
        }
    }

    Rectangle {
        border-radius: 10px;
        background: root.selected ? Theme.bg-selected : (t.has-hover ? Theme.bg-card-hover : Theme.bg-card);
        border-width: 1px;
        border-color: root.selected ? Theme.border-accent : Theme.border;
        clip: true;
        animate background { duration: 140ms; }

        HorizontalLayout {
            padding: 10px; spacing: 10px;

            // Checkbox slot — always reserves space in multi-select mode
            if root.multi-select-mode: Rectangle {
                width: 18px;
                VerticalLayout {
                    alignment: center;
                    Checkbox {
                        checked: root.checked;
                        toggled => { root.check-toggled(); }
                    }
                }
            }

            Rectangle {
                width: 56px; height: 56px; border-radius: 8px;
                background: Theme.bg-elevated;
                if !root.data.has-photo: Text {
                    text: "📷"; font-family: "Segoe UI Emoji"; font-size: 22px;
                    width: parent.width; height: parent.height;
                    horizontal-alignment: center; vertical-alignment: center;
                    color: Theme.text-muted;
                }
                if root.data.has-photo: Rectangle {
                    width: 56px; height: 56px; border-radius: 8px; clip: true;
                    Image {
                        source: root.data.thumbnail;
                        width: 56px; height: 56px; image-fit: cover;
                    }
                }
            }

            VerticalLayout {
                alignment: center; spacing: 4px; horizontal-stretch: 1;
                Text {
                    text: root.data.name; font-size: Theme.ui-font-size; font-weight: 600;
                    font-family: Theme.content-font;
                    overflow: elide;
                    color: root.selected ? Theme.text-primary : Theme.text-secondary;
                }
                Rectangle {
                    height: max(10px, Theme.ui-font-size - 2px) * 2.5;
                    clip: true;
                    Text {
                        text: root.data.short-desc;
                        font-size: max(10px, Theme.ui-font-size - 2px);
                        font-family: Theme.content-font;
                        color: Theme.text-muted;
                        wrap: word-wrap;
                        overflow: elide;
                        x: 0; y: 0; width: parent.width;
                    }
                }
            }
        }
    }
}

// ─── Name Input Modal (rename / save template with name) ──────────────────────

component NameInputModal {
    in property <string> title;
    in-out property <string> value;
    callback accepted(string);
    callback close();

    init => { ti.focus(); ti.select-all(); }

    // Scrim
    TouchArea {
        width: parent.width; height: parent.height;
        clicked => { root.close(); }
    }

    Rectangle {
        x: (parent.width  - 320px) / 2;
        y: (parent.height - 150px) / 2;
        width: 320px; height: 150px;
        border-radius: 12px; background: Theme.bg-panel;
        border-width: 1px; border-color: Theme.border;
        drop-shadow-blur: 24px; drop-shadow-color: #00000050;

        TouchArea { width: parent.width; height: parent.height; }

        VerticalLayout {
            padding: 18px; spacing: 12px;

            Text { text: root.title; font-size: Theme.ui-font-size; font-weight: 700; color: Theme.text-primary; }

            Rectangle {
                height: 36px; border-radius: 6px;
                background: Theme.bg-input; border-width: 1px; border-color: Theme.accent-dim;
                ti := TextInput {
                    text <=> root.value;
                    font-size: Theme.ui-font-size; color: Theme.text-primary;
                    font-family: Theme.content-font;
                    x: 10px; width: parent.width - 20px; height: parent.height;
                    vertical-alignment: center;
                    accepted => { root.accepted(self.text); }
                }
            }

            HorizontalLayout {
                spacing: 8px; alignment: end;
                cancel-t := TouchArea {
                    width: 76px; height: 30px; clicked => { root.close(); }
                    Rectangle {
                        border-radius: 6px;
                        background: cancel-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                        border-width: 1px; border-color: Theme.border;
                        Text { text: "Cancel"; font-size: Theme.ui-font-size - 2px; color: Theme.text-secondary; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
                ok-t := TouchArea {
                    width: 76px; height: 30px; clicked => { root.accepted(root.value); }
                    Rectangle {
                        border-radius: 6px;
                        background: ok-t.has-hover ? Theme.accent : Theme.accent-dim;
                        Text { text: "OK"; font-size: Theme.ui-font-size - 2px; font-weight: 600; color: #fff; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }
    }
}

// Large multiline field editor (for description and long custom fields)
component FieldEditorModal {
    in property <string> title;
    in-out property <string> value;
    in property <int> word-count: 0;
    in property <int> word-limit: 200;
    callback accepted(string);
    callback close();
    callback text-edited(string);

    // Default to a large share of the window; user can still drag-resize.
    // Rounded to whole pixels so text isn't rendered off the pixel grid (blurry).
    property <length> mw: round(clamp(root.width * 70%, 420px, 1100px) / 1px) * 1px;
    property <length> mh: round(clamp(root.height * 75%, 320px, 820px) / 1px) * 1px;

    init => { fe.focus(); }

    TouchArea {
        width: parent.width; height: parent.height;
        clicked => { root.close(); }
    }

    panel := Rectangle {
        x: round((parent.width  - root.mw) / 2 / 1px) * 1px;
        y: round((parent.height - root.mh) / 2 / 1px) * 1px;
        width: root.mw; height: root.mh;
        border-radius: 12px; background: Theme.bg-panel;
        border-width: 1px; border-color: Theme.border;
        drop-shadow-blur: 24px; drop-shadow-color: #00000050;

        TouchArea { width: parent.width; height: parent.height; }

        VerticalLayout {
            padding: 18px; spacing: 12px;

            Text { text: root.title; font-size: Theme.ui-font-size; font-weight: 700; color: Theme.text-primary; }

            // Tall scrollable editing area — custom scroll
            root2 := Rectangle {
                vertical-stretch: 1;
                border-radius: 6px;
                background: Theme.bg-input; border-width: 1px; border-color: Theme.accent-dim;
                clip: true;

                property <length> content-h: fe.preferred-height;
                property <length> view-h: self.height - 8px;
                property <length> max-scroll: max(0px, root2.content-h - root2.view-h);
                property <length> scroll-y: 0px;

                // I-beam cursor over the editor area (sits behind the text input)
                ibeam := TouchArea {
                    width: parent.width; height: parent.height;
                    mouse-cursor: text;
                    clicked => { fe.focus(); }
                }

                // Moving wrapper holds the TextInput; we shift the wrapper, not the input
                Rectangle {
                    x: 8px; y: round((4px - root2.scroll-y) / 1px) * 1px;
                    width: parent.width - 22px;
                    height: max(root2.content-h, root2.view-h);
                    fe := TextInput {
                        width: parent.width; height: parent.height;
                        text <=> root.value;
                        font-size: Theme.ui-font-size; color: Theme.text-primary;
                        font-family: Theme.content-font;
                        wrap: word-wrap; single-line: false;
                        edited => { root.text-edited(self.text); }
                    }
                }

                // Scrollbar track (only when content overflows)
                if root2.max-scroll > 0px: track := Rectangle {
                    x: parent.width - 10px; y: 2px;
                    width: 6px; height: parent.height - 4px;
                    background: Theme.bg-surface; border-radius: 3px;

                    property <length> thumb-h: max(24px, self.height * (root2.view-h / root2.content-h));

                    thumb := Rectangle {
                        width: parent.width;
                        height: track.thumb-h;
                        y: (track.height - track.thumb-h) * (root2.scroll-y / root2.max-scroll);
                        background: track-ta.pressed ? Theme.accent : Theme.text-muted;
                        border-radius: 3px;
                    }

                    track-ta := TouchArea {
                        width: parent.width; height: parent.height;
                        moved => {
                            root2.scroll-y = clamp(
                                (self.mouse-y - track.thumb-h / 2) / (track.height - track.thumb-h) * root2.max-scroll,
                                0px, root2.max-scroll);
                        }
                        clicked => {
                            root2.scroll-y = clamp(
                                (self.mouse-y - track.thumb-h / 2) / (track.height - track.thumb-h) * root2.max-scroll,
                                0px, root2.max-scroll);
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: 8px; alignment: end;
                Text {
                    text: root.word-count + " / " + root.word-limit + " words";
                    font-size: Theme.ui-font-size - 3px;
                    color: root.word-count > root.word-limit ? Theme.danger-text : Theme.text-muted;
                    vertical-alignment: center; horizontal-stretch: 1;
                }
                cancel-t := TouchArea {
                    width: 76px; height: 30px; clicked => { root.close(); }
                    Rectangle {
                        border-radius: 6px;
                        background: cancel-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                        border-width: 1px; border-color: Theme.border;
                        Text { text: "Cancel"; font-size: Theme.ui-font-size - 2px; color: Theme.text-secondary; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
                ok-t := TouchArea {
                    width: 76px; height: 30px; clicked => { root.accepted(root.value); }
                    Rectangle {
                        border-radius: 6px;
                        background: ok-t.has-hover ? Theme.accent : Theme.accent-dim;
                        Text { text: "Save"; font-size: Theme.ui-font-size - 2px; font-weight: 600; color: #fff; horizontal-alignment: center; vertical-alignment: center; }
                    }
                }
            }
        }

        // Resize handle (bottom-right corner)
        resize-ta := TouchArea {
            x: parent.width - 20px; y: parent.height - 20px;
            width: 20px; height: 20px;
            mouse-cursor: nwse-resize;
            property <length> start-w;
            property <length> start-h;
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down) {
                    self.start-w = root.mw; self.start-h = root.mh;
                }
            }
            moved => {
                root.mw = clamp(self.start-w + (self.mouse-x - self.pressed-x) * 2, 320px, 1100px);
                root.mh = clamp(self.start-h + (self.mouse-y - self.pressed-y) * 2, 240px, 820px);
            }
            Rectangle {
                width: 100%; height: 100%;
                Path {
                    commands: "M 18 6 L 6 18 M 18 11 L 11 18 M 18 16 L 16 18";
                    stroke: Theme.text-muted; stroke-width: 1.5px;
                }
            }
        }
    }
}

// ─── Sort Bar (label + toggle; the menu is rendered as a top-level overlay) ──
// Mode 0 = Date added. 1=Name A-Z, 2=Name Z-A, 3=count-asc/date-old, 4=count-desc/date-new.

component SortBar {
    in property <int> mode;
    in property <bool> is-collection;
    in property <bool> open;
    callback toggle();

    property <string> lbl0: "Date added";
    property <string> lbl1: "Name A–Z";
    property <string> lbl2: "Name Z–A";
    property <string> lbl3: root.is-collection ? "Fewest items" : "Oldest first";
    property <string> lbl4: root.is-collection ? "Most items"   : "Newest first";

    property <string> current:
          root.mode == 1 ? root.lbl1
        : root.mode == 2 ? root.lbl2
        : root.mode == 3 ? root.lbl3
        : root.mode == 4 ? root.lbl4
        : root.lbl0;

    height: 26px;
    bar := TouchArea {
        clicked => { root.toggle(); }
        Rectangle {
            border-radius: 6px;
            background: (root.open || bar.has-hover) ? Theme.bg-surface : transparent;
            HorizontalLayout {
                padding-left: 10px; padding-right: 10px; spacing: 6px; alignment: start;
                Text { text: "Sort:"; font-size: Theme.ui-font-size - 3px; color: Theme.text-muted; vertical-alignment: center; }
                Text {
                    text: root.current;
                    font-size: Theme.ui-font-size - 3px; font-weight: 600;
                    color: root.mode == 0 ? Theme.text-secondary : Theme.accent;
                    vertical-alignment: center; horizontal-stretch: 1;
                }
                Text { text: root.open ? "▲" : "▼"; font-size: Theme.ui-font-size - 5px; color: Theme.text-muted; vertical-alignment: center; }
            }
        }
    }
}

// Standalone menu list used as an overlay (renders above panels)
component SortMenu inherits Rectangle {
    in property <int> mode;
    in property <bool> is-collection;
    callback pick(int);
    property <string> lbl3: root.is-collection ? "Fewest items" : "Oldest first";
    property <string> lbl4: root.is-collection ? "Most items"   : "Newest first";
    width: 170px; height: 5 * 28px + 8px;
    border-radius: 8px;
    background: Theme.bg-elevated;
    border-width: 1px; border-color: Theme.border;
    drop-shadow-blur: 16px; drop-shadow-color: #00000066;
    VerticalLayout {
        padding: 4px; spacing: 0px;
        for opt[idx] in ["Date added", "Name A–Z", "Name Z–A", root.lbl3, root.lbl4]: o-t := TouchArea {
            height: 28px;
            clicked => { root.pick(idx); }
            Rectangle {
                border-radius: 5px;
                background: idx == root.mode ? Theme.accent-dim : (o-t.has-hover ? Theme.bg-surface : transparent);
                Text {
                    text: opt;
                    font-size: Theme.ui-font-size - 3px;
                    color: idx == root.mode ? Theme.accent-text : Theme.text-primary;
                    x: 10px; vertical-alignment: center;
                }
            }
        }
    }
}

// ─── Root Window ──────────────────────────────────────────────────────────────

export component AppWindow inherits Window {
    title: "Collector";
    icon: root.window-icon;
    in property <image> window-icon;
    min-width: 820px; min-height: 540px;
    preferred-width: 1200px; preferred-height: 760px;
    background: Theme.bg-base;
    default-font-family: Theme.content-font;
    forward-focus: fs;

    in-out property <length> left-width: 220px;
    in-out property <length> mid-width:  268px;

    // Collections & items
    in-out property <[CollectionData]> collections: [];
    in-out property <[ItemData]>       items: [];
    in-out property <[FieldData]>      detail-fields: [];
    in-out property <[TemplateData]>   templates: [];
    in-out property <[CheckedItem]>    coll-checked: [];
    in-out property <[CheckedItem]>    item-checked: [];
    in-out property <int>    selected-collection: -1;
    in-out property <int>    selected-item: -1;
    in-out property <string> search-text: "";
    in-out property <string> coll-search-text: "";
    in-out property <int>    coll-sort-mode: 0;
    in-out property <int>    item-sort-mode: 0;
    in-out property <bool>   coll-sort-open: false;
    in-out property <bool>   item-sort-open: false;

    // Detail panel
    in-out property <string> detail-name: "";
    in-out property <string> detail-desc: "";
    in-out property <string> detail-year: "";
    in-out property <string> detail-month: "";
    in-out property <string> detail-day: "";
    in-out property <bool>   detail-has-photo: false;
    in-out property <image>  detail-photo;
    in-out property <[PhotoData]> detail-photos: [];
    in-out property <int>    lightbox-index: 0;
    in-out property <image>  lightbox-photo;
    in-out property <int>    lightbox-count: 0;

    // UI state
    in-out property <bool>   is-editing: false;
    in-out property <bool>   show-settings: false;
    in-out property <bool>   show-icon-picker: false;
    in-out property <bool>   show-template-picker: false;
    in-out property <bool>   show-lightbox: false;
    in-out property <bool>   coll-multi-mode: false;
    in-out property <bool>   item-multi-mode: false;
    in-out property <string> status-message: "";

    // Context menu
    in-out property <bool>   show-context-menu: false;
    in-out property <bool>   ctx-is-collection: false;
    in-out property <bool>   ctx-multi: false;
    in-out property <int>    ctx-target: -1;
    in-out property <length> ctx-x: 0px;
    in-out property <length> ctx-y: 0px;

    // Name-input modal (used for rename + save-template-with-name)
    in-out property <bool>   show-name-input: false;
    in-out property <string> name-input-title: "";
    in-out property <string> name-input-value: "";
    in-out property <string> name-input-purpose: "";  // "rename-coll" | "rename-item" | "save-template"
    in-out property <int>    name-input-target: -1;

    // Large multiline field editor modal
    in-out property <bool>   show-field-editor: false;
    in-out property <string> field-editor-title: "";
    in-out property <string> field-editor-value: "";
    in-out property <string> field-editor-purpose: "";  // "desc" | field id
    in-out property <int>    field-editor-wordcount: 0;

    // Callbacks
    callback select-collection(int, bool, bool);  // idx, ctrl, shift
    callback select-item(int, bool, bool);
    callback new-collection();
    callback delete-collection(int);
    callback duplicate-collection(int);
    callback new-item();
    callback delete-item(int);
    callback duplicate-item(int);
    callback delete-selected-items();
    callback duplicate-selected-items();
    callback delete-selected-collections();
    callback duplicate-selected-collections();
    callback toggle-edit();
    callback pick-photo();
    callback remove-photo(int);
    callback set-main-photo(int);
    callback lightbox-load(int);  // load full-res photo at index into lightbox-photo
    callback count-words(string);  // count words in field editor, updates field-editor-wordcount
    callback field-changed(string, string);
    callback resize-left(length);
    callback resize-mid(length);
    callback toggle-dark-mode();
    callback set-accent(color);
    callback set-font-size(length);
    callback export-data();
    callback import-data();
    callback open-data-folder();
    callback search-changed(string);
    callback search-collections(string);
    callback set-coll-sort(int);
    callback set-item-sort(int);
    callback collection-icon-clicked(int);
    callback icon-picked(string);
    callback add-custom-field();
    callback delete-custom-field(string);
    callback custom-field-label-changed(string, string);
    callback custom-field-value-changed(string, string);
    callback save-template-named(string);
    callback apply-template(string);
    callback delete-template(string);
    callback rename-template(string, string);
    callback rename-collection(int, string);
    callback rename-item(int, string);
    callback clear-selection();
    callback toggle-coll-check(int);
    callback toggle-item-check(int);
    callback coll-right-clicked(int, length, length);
    callback item-right-clicked(int, length, length);

    // ── FocusScope wraps everything so capture-key sees all key events ───────
    fs := FocusScope {
        width: root.width; height: root.height;
        enabled: true;
        // Reclaim focus on click in non-input areas, so Esc always works.
        // TextInputs inside still grab focus on their own click.
        focus-on-click: true;
        capture-key-pressed(event) => {
            if (event.text == Key.Escape) {
                root.clear-selection();
            }
            reject
        }

        // ── Main layout ──────────────────────────────────────────────────────
        HorizontalLayout {
            spacing: 0px;

        // ══ LEFT PANEL ════════════════════════════════════════════════════════
        Rectangle {
            width: root.left-width;
            background: Theme.bg-panel;

            VerticalLayout {
                padding: 14px; padding-top: 18px; spacing: 6px;

                // Header
                HorizontalLayout {
                    alignment: space-between; height: 38px;
                    Text {
                        text: "Collections";
                        font-size: Theme.ui-font-size - 1px;
                        letter-spacing: 1.2px; font-weight: 700;
                        color: Theme.text-muted; vertical-alignment: center;
                    }
                    HorizontalLayout {
                        spacing: 2px; alignment: center;
                        SmallBtn { label: "⚙"; active: root.show-settings; clicked => { root.show-settings = !root.show-settings; } }
                        SmallBtn { label: "+"; clicked => { root.new-collection(); } }
                    }
                }

                // Collection search box
                Rectangle {
                    height: 30px; border-radius: 8px;
                    background: Theme.bg-surface; border-width: 1px; border-color: Theme.border;

                    if root.coll-search-text == "": Text {
                        text: "Filter collections...";
                        font-size: Theme.ui-font-size - 3px; color: Theme.text-muted;
                        x: 12px; width: parent.width - 24px; height: parent.height;
                        vertical-alignment: center;
                    }
                    coll-search-input := TextInput {
                        text <=> root.coll-search-text;
                        font-size: Theme.ui-font-size - 3px; color: Theme.text-primary;
                        font-family: Theme.content-font;
                        x: 12px; width: parent.width - 40px; height: parent.height;
                        vertical-alignment: center;
                        edited => { root.search-collections(self.text); }
                        key-pressed(e) => {
                            if (e.text == Key.Escape) {
                                root.coll-search-text = "";
                                root.search-collections("");
                                fs.focus();
                                accept
                            } else {
                                reject
                            }
                        }
                    }
                    if root.coll-search-text != "": cclr-t := TouchArea {
                        x: parent.width - 26px; y: 5px;
                        width: 20px; height: 20px;
                        clicked => { root.coll-search-text = ""; root.search-collections(""); fs.focus(); }
                        Rectangle {
                            border-radius: 4px;
                            background: cclr-t.has-hover ? Theme.bg-elevated : transparent;
                            Text { text: "×"; font-size: 13px; color: Theme.text-muted; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }

                Rectangle { height: 4px; }
                SortBar {
                    mode: root.coll-sort-mode; is-collection: true; open: root.coll-sort-open;
                    toggle => { root.item-sort-open = false; root.coll-sort-open = !root.coll-sort-open; }
                }

                // Collection list
                ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 2px; padding-right: 2px;

                        for coll[i] in root.collections: CollectionRow {
                            data: coll;
                            selected: root.selected-collection == i;
                            multi-select-mode: root.coll-multi-mode;
                            checked: root.coll-checked.length > i && root.coll-checked[i].checked;
                            row-visible: coll.row-match;
                            clicked(ctrl, shift) => { root.coll-sort-open = false; root.item-sort-open = false; root.select-collection(i, ctrl, shift); fs.focus(); }
                            double-clicked => {
                                root.name-input-title = "Rename collection";
                                root.name-input-value = coll.name;
                                root.name-input-purpose = "rename-coll";
                                root.name-input-target = i;
                                root.show-name-input = true;
                            }
                            icon-clicked => { root.collection-icon-clicked(i); }
                            check-toggled => { root.toggle-coll-check(i); }
                            right-clicked(mx, my) => { root.coll-right-clicked(i, mx, my); }
                        }

                        if root.collections.length == 0: Rectangle {
                            height: 120px;
                            VerticalLayout {
                                alignment: center; spacing: 8px;
                                Text {
                                    text: "🗂";
                                    font-family: "Segoe UI Emoji";
                                    font-size: 36px;
                                    horizontal-alignment: center;
                                    color: Theme.text-muted;
                                }
                                Text {
                                    text: "Press + to create\na collection";
                                    font-size: Theme.ui-font-size - 2px;
                                    color: Theme.text-muted; horizontal-alignment: center;
                                }
                            }
                        }
                    }
                }

                // Bottom actions
                VerticalLayout {
                    spacing: 4px;

                    ms-t := TouchArea {
                        height: 36px; clicked => {
                            root.clear-selection();
                            fs.focus();
                        }
                        Rectangle {
                            border-radius: 6px;
                            background: (root.coll-multi-mode || root.item-multi-mode) ? Theme.accent-dim : (ms-t.has-hover ? Theme.bg-elevated : transparent);
                            border-width: (root.coll-multi-mode || root.item-multi-mode) ? 1px : 0px;
                            border-color: Theme.border-accent;
                            if (root.coll-multi-mode || root.item-multi-mode): Text {
                                text: "Clear selection (Esc)";
                                font-size: Theme.ui-font-size - 4px;
                                color: Theme.accent-text;
                                vertical-alignment: center; horizontal-alignment: center;
                            }
                            if !(root.coll-multi-mode || root.item-multi-mode): VerticalLayout {
                                alignment: center; spacing: 2px;
                                Text {
                                    text: "Ctrl/Shift-click to multi-select";
                                    font-size: Theme.ui-font-size - 4px; color: Theme.text-muted;
                                    horizontal-alignment: center;
                                }
                                Text {
                                    text: "Right-click for options";
                                    font-size: Theme.ui-font-size - 4px; color: Theme.text-muted;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }
                }
            }
        }

        DragHandle {
            drag(delta) => {
                root.left-width = max(140px, min(360px, root.left-width + delta));
                root.resize-left(root.left-width);
            }
        }

        // ══ MIDDLE PANEL ══════════════════════════════════════════════════════
        Rectangle {
            width: root.mid-width;
            background: Theme.bg-base;

            VerticalLayout {
                padding: 14px; padding-top: 18px; spacing: 6px;

                // Header
                HorizontalLayout {
                    alignment: space-between; height: 38px;
                    Text {
                        text: root.selected-collection >= 0
                            ? root.collections[root.selected-collection].name
                            : "Items";
                        font-size: Theme.ui-font-size + 1px; font-weight: 700;
                        font-family: Theme.content-font;
                        color: Theme.text-primary; vertical-alignment: center; overflow: elide;
                    }
                    HorizontalLayout {
                        spacing: 4px; alignment: center;
                        if root.selected-collection >= 0 && root.item-multi-mode: del-sel-t := TouchArea {
                            width: 60px; height: 26px;
                            clicked => { root.delete-selected-items(); }
                            Rectangle {
                                border-radius: 6px;
                                background: del-sel-t.has-hover ? Theme.danger-bg : transparent;
                                border-width: 1px; border-color: #3d1515;
                                Text { text: "× Delete"; font-size: Theme.ui-font-size - 3px; color: Theme.danger-text; horizontal-alignment: center; vertical-alignment: center; }
                            }
                        }
                        if root.selected-collection >= 0: SmallBtn { label: "+"; clicked => { root.new-item(); } }
                    }
                }

                // Search bar
                if root.selected-collection >= 0: Rectangle {
                    height: 32px; border-radius: 8px;
                    background: Theme.bg-surface; border-width: 1px; border-color: Theme.border;

                    // Placeholder text (non-interactive, behind input)
                    if root.search-text == "": Text {
                        text: "Search...";
                        font-size: Theme.ui-font-size - 2px; color: Theme.text-muted;
                        x: 12px; width: parent.width - 24px; height: parent.height;
                        vertical-alignment: center;
                    }

                    // TextInput fills the whole bar so it's always clickable
                    search-input := TextInput {
                        text <=> root.search-text;
                        font-size: Theme.ui-font-size - 2px; color: Theme.text-primary;
                        font-family: Theme.content-font;
                        x: 12px; width: parent.width - 40px; height: parent.height;
                        vertical-alignment: center;
                        edited => { root.search-changed(self.text); }
                        key-pressed(e) => {
                            if (e.text == Key.Escape) {
                                root.search-text = "";
                                root.search-changed("");
                                root.clear-selection();
                                fs.focus();
                                accept
                            } else {
                                reject
                            }
                        }
                    }

                    // Clear button
                    if root.search-text != "": clr-t := TouchArea {
                        x: parent.width - 28px; y: 6px;
                        width: 20px; height: 20px;
                        clicked => {
                            root.search-text = "";
                            root.search-changed("");
                            fs.focus();
                        }
                        Rectangle {
                            border-radius: 4px;
                            background: clr-t.has-hover ? Theme.bg-elevated : transparent;
                            Text { text: "×"; font-size: 13px; color: Theme.text-muted; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }

                if root.selected-collection >= 0: Rectangle { height: 4px; }
                if root.selected-collection >= 0: SortBar {
                    mode: root.item-sort-mode; is-collection: false; open: root.item-sort-open;
                    toggle => { root.coll-sort-open = false; root.item-sort-open = !root.item-sort-open; }
                }

                // No collection selected
                if root.selected-collection < 0: Rectangle {
                    vertical-stretch: 1;
                    VerticalLayout {
                        alignment: center; spacing: 8px;
                        Text { text: "←"; font-size: Theme.ui-font-size + 8px; horizontal-alignment: center; color: Theme.text-muted; }
                        Text { text: "Select a collection"; font-size: Theme.ui-font-size - 2px; color: Theme.text-muted; horizontal-alignment: center; }
                    }
                }

                // Item list
                if root.selected-collection >= 0: ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 5px; padding-right: 2px;

                        for item[i] in root.items: ItemCard {
                            data: item;
                            selected: root.selected-item == i;
                            multi-select-mode: root.item-multi-mode;
                            checked: root.item-checked.length > i && root.item-checked[i].checked;
                            clicked(ctrl, shift) => { root.select-item(i, ctrl, shift); fs.focus(); }
                            double-clicked => {
                                root.name-input-title = "Rename item";
                                root.name-input-value = item.name;
                                root.name-input-purpose = "rename-item";
                                root.name-input-target = i;
                                root.show-name-input = true;
                            }
                            check-toggled => { root.toggle-item-check(i); }
                            right-clicked(mx, my) => { root.item-right-clicked(i, mx, my); }
                        }

                        if root.items.length == 0: VerticalLayout {
                            alignment: center; spacing: 8px;
                            Text { text: "📦"; font-family: "Segoe UI Emoji"; font-size: 36px; height: 52px; horizontal-alignment: center; vertical-alignment: center; color: Theme.text-muted; }
                            Text { text: "Press + to add an item"; font-size: Theme.ui-font-size - 2px; color: Theme.text-muted; horizontal-alignment: center; }
                        }
                    }
                }
            }
        }

        DragHandle {
            drag(delta) => {
                root.mid-width = max(180px, min(460px, root.mid-width + delta));
                root.resize-mid(root.mid-width);
            }
        }

        // ══ RIGHT PANEL ═══════════════════════════════════════════════════════
        Rectangle {
            horizontal-stretch: 1;
            background: Theme.bg-panel;

            if root.selected-item < 0: VerticalLayout {
                alignment: center; spacing: 10px;
                Text { text: "🔍"; font-family: "Segoe UI Emoji"; font-size: 36px; height: 52px; horizontal-alignment: center; vertical-alignment: center; color: Theme.text-muted; }
                Text { text: "Select an item to view details"; font-size: Theme.ui-font-size - 2px; color: Theme.text-muted; horizontal-alignment: center; }
            }

            if root.selected-item >= 0: ScrollView {
                VerticalLayout {
                    padding: 22px; spacing: 0px;
                    alignment: start;

                // Top bar
                HorizontalLayout {
                    alignment: space-between; height: 46px;
                    Text {
                        text: root.detail-name == "" ? "New Item" : root.detail-name;
                        font-size: Theme.ui-font-size + 2px; font-weight: 700;
                        font-family: Theme.content-font;
                        color: Theme.text-primary; vertical-alignment: center; overflow: elide;
                    }
                    HorizontalLayout {
                        spacing: 5px; alignment: center;
                        save-t := TouchArea {
                            width: 84px; height: 34px;
                            clicked => { root.toggle-edit(); }
                            HorizontalLayout {
                                alignment: center; spacing: 4px;
                                Text {
                                    text: root.is-editing ? "💾" : "✏";
                                    font-family: "Segoe UI Emoji";
                                    font-size: Theme.ui-font-size - 2px;
                                    height: 34px; vertical-alignment: center;
                                }
                                Text {
                                    text: root.is-editing ? "Save" : "Edit";
                                    font-size: Theme.ui-font-size - 1px; font-weight: 600;
                                    color: root.is-editing ? Theme.accent-text
                                         : (save-t.has-hover ? Theme.text-primary : Theme.text-secondary);
                                    height: 34px; vertical-alignment: center;
                                }
                            }
                        }
                        del-item-t := TouchArea {
                            width: 92px; height: 34px;
                            clicked => { root.delete-item(root.selected-item); }
                            Rectangle {
                                border-radius: 6px;
                                background: del-item-t.has-hover ? Theme.danger-bg : transparent;
                                HorizontalLayout {
                                    alignment: center; spacing: 4px;
                                    Text {
                                        text: "🗑"; font-family: "Segoe UI Emoji";
                                        font-size: Theme.ui-font-size - 2px;
                                        height: 34px; vertical-alignment: center;
                                    }
                                    Text {
                                        text: "Delete";
                                        font-size: Theme.ui-font-size - 1px; font-weight: 600;
                                        color: Theme.danger-text;
                                        height: 34px; vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle { height: 4px; }

                // Photo + name/desc
                HorizontalLayout {
                    spacing: 18px; height: 152px;

                    // Photo box
                    Rectangle {
                        width: 140px; height: 140px; border-radius: 11px;
                        background: Theme.bg-surface; border-width: 1px; border-color: Theme.border;
                        clip: true;

                        if !root.detail-has-photo: VerticalLayout {
                            alignment: center; spacing: 6px;
                            Text { text: "📷"; font-family: "Segoe UI Emoji"; font-size: 32px; height: 46px; horizontal-alignment: center; vertical-alignment: center; color: Theme.text-muted; }
                            if root.is-editing: Text { text: "Click to add"; font-size: Theme.ui-font-size - 4px; color: Theme.text-muted; horizontal-alignment: center; }
                        }

                        if root.detail-has-photo: Image {
                            source: root.detail-photo;
                            width: 140px; height: 140px; image-fit: cover;
                        }

                        // Edit mode — click to change photo
                        if root.is-editing: edit-photo-t := TouchArea {
                            clicked => { root.pick-photo(); }
                            Rectangle {
                                border-radius: 11px; background: #00000055;
                                visible: edit-photo-t.has-hover;
                                Text {
                                    text: "Add"; font-size: Theme.ui-font-size - 3px;
                                    color: #fff; font-weight: 600;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                        }

                        // View mode — click to open lightbox
                        if !root.is-editing && root.detail-has-photo: view-photo-t := TouchArea {
                            clicked => {
                                root.lightbox-index = 0;
                                root.lightbox-count = root.detail-photos.length;
                                root.lightbox-load(0);
                                root.show-lightbox = true;
                            }
                            Rectangle {
                                border-radius: 11px; background: #00000040;
                                visible: view-photo-t.has-hover;
                                Text {
                                    text: "Enlarge"; font-size: Theme.ui-font-size - 3px;
                                    color: #fff; font-weight: 600;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Name and short description
                    VerticalLayout {
                        alignment: start; spacing: 10px;

                        VerticalLayout {
                            spacing: 3px;
                            SectionLabel { text: "NAME"; }
                            Rectangle {
                                height: 36px; border-radius: 6px;
                                background: root.is-editing ? Theme.bg-input : transparent;
                                border-width: root.is-editing ? 1px : 0px;
                                border-color: Theme.accent-dim;
                                animate background { duration: 130ms; }
                                if root.is-editing: TextInput {
                                    text <=> root.detail-name;
                                    font-size: Theme.ui-font-size + 1px; font-weight: 600;
                                    font-family: Theme.content-font;
                                    color: Theme.text-primary;
                                    x: 10px; width: parent.width - 20px; height: parent.height;
                                    vertical-alignment: center;
                                    edited => { root.field-changed("name", self.text); }
                                }
                                if !root.is-editing: Text {
                                    text: root.detail-name; font-size: Theme.ui-font-size + 1px; font-weight: 600;
                                    font-family: Theme.content-font;
                                    color: Theme.text-primary; vertical-alignment: center; x: 2px;
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 3px;
                            Rectangle {
                                height: 22px;
                                SectionLabel { text: "DESCRIPTION"; width: parent.width; }
                                edit-desc-t := TouchArea {
                                    x: parent.width - 56px; y: 2px;
                                    width: 56px; height: 18px;
                                    clicked => {
                                        root.field-editor-title = "Description";
                                        root.field-editor-value = root.detail-desc;
                                        root.field-editor-purpose = "desc";
                                        root.show-field-editor = true;
                                    }
                                    Rectangle {
                                        border-radius: 4px;
                                        background: edit-desc-t.has-hover ? Theme.bg-elevated : transparent;
                                        Text { text: "Enlarge"; font-size: max(9px, Theme.ui-font-size - 4px); color: Theme.text-secondary; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                            }
                            Rectangle {
                                height: 72px; border-radius: 6px;
                                background: Theme.bg-input;
                                border-width: root.is-editing ? 1px : 0px;
                                border-color: Theme.accent-dim;
                                clip: true;
                                animate background { duration: 130ms; }
                                desc-focus-ta := TouchArea {
                                    width: parent.width; height: parent.height;
                                    enabled: root.is-editing;
                                    mouse-cursor: text;
                                    clicked => { desc-input.focus(); }
                                }
                                desc-input := TextInput {
                                    text <=> root.detail-desc;
                                    font-size: Theme.ui-font-size;
                                    font-family: Theme.content-font;
                                    color: Theme.text-primary;
                                    x: 8px; y: 6px; width: parent.width - 14px; height: parent.height - 12px;
                                    wrap: word-wrap; single-line: false;
                                    read-only: !root.is-editing;
                                }
                                if !root.is-editing && root.detail-desc == "": Text {
                                    text: "No description";
                                    font-size: Theme.ui-font-size; color: Theme.text-muted;
                                    x: 12px; y: 8px;
                                }
                            }
                        }
                    }
                }

                // Photo strip — all photos; click=set main (or right-click), ×=remove in edit mode
                if root.detail-photos.length > 1 || (root.is-editing && root.detail-photos.length >= 1): VerticalLayout {
                    spacing: 3px;
                    Rectangle { height: 24px; }
                    SectionLabel { text: "PHOTOS"; }
                    Rectangle {
                        height: 58px;
                        clip: true;
                        Flickable {
                            width: 100%; height: 58px;
                            viewport-width: root.detail-photos.length * 62px;
                            viewport-height: 56px;
                        for ph[i] in root.detail-photos: Rectangle {
                            x: i * 62px; y: 0;
                            width: 56px; height: 56px; border-radius: 8px;
                            background: Theme.bg-surface;
                            border-width: ph.is-main ? 2px : 1px;
                            border-color: ph.is-main ? Theme.accent : Theme.border;
                            clip: true;

                            strip-t := TouchArea {
                                clicked => {
                                    if root.is-editing {
                                        root.set-main-photo(ph.index);
                                    } else {
                                        root.lightbox-index = ph.index;
                                        root.lightbox-count = root.detail-photos.length;
                                        root.lightbox-load(ph.index);
                                        root.show-lightbox = true;
                                    }
                                }
                                Image {
                                    source: ph.thumbnail;
                                    width: 100%; height: 100%; image-fit: cover;
                                }
                            }

                            if ph.is-main: Rectangle {
                                x: 0; y: 0; width: 100%; height: 15px;
                                background: Theme.accent;
                                Text {
                                    text: "main"; font-size: 9px; color: #fff; font-weight: 700;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }

                            if root.is-editing: rm-ph-t := TouchArea {
                                x: parent.width - 18px; y: 2px; width: 16px; height: 16px;
                                clicked => { root.remove-photo(ph.index); }
                                Rectangle {
                                    border-radius: 8px; background: #cc3333;
                                    Text { text: "×"; font-size: 12px; color: #fff; font-weight: 700;
                                           horizontal-alignment: center; vertical-alignment: center; }
                                }
                            }
                        }
                    }
                    }
                    if root.is-editing: Text {
                        text: "Click to set as main · × to remove";
                        font-size: Theme.ui-font-size - 5px; color: Theme.text-muted;
                    }
                    if !root.is-editing: Text {
                        text: "Click a photo to enlarge. Drag to scroll.";
                        font-size: Theme.ui-font-size - 5px; color: Theme.text-muted;
                    }
                }

                Rectangle { height: 12px; }
                VerticalLayout {
                    spacing: 3px;
                    SectionLabel { text: "DATE ACQUIRED"; }
                    if root.is-editing: HorizontalLayout {
                        spacing: 6px; height: 34px; alignment: start;
                        // Year
                        Rectangle {
                            width: 70px; border-radius: 6px;
                            background: Theme.bg-input; border-width: 1px; border-color: Theme.accent-dim;
                            if root.detail-year == "": Text { text: "YYYY"; font-size: Theme.ui-font-size - 2px; color: Theme.text-muted; x: 8px; vertical-alignment: center; }
                            TextInput {
                                text <=> root.detail-year;
                                font-size: Theme.ui-font-size - 1px; color: Theme.text-primary;
                                x: 8px; width: parent.width - 16px; height: parent.height; vertical-alignment: center;
                                input-type: number;
                                edited => {
                                    if self.text.character-count > 4 { self.text = root.detail-year; }
                                }
                            }
                        }
                        Text { text: "-"; color: Theme.text-muted; vertical-alignment: center; }
                        // Month
                        Rectangle {
                            width: 48px; border-radius: 6px;
                            background: Theme.bg-input; border-width: 1px; border-color: Theme.accent-dim;
                            if root.detail-month == "": Text { text: "MM"; font-size: Theme.ui-font-size - 2px; color: Theme.text-muted; x: 8px; vertical-alignment: center; }
                            TextInput {
                                text <=> root.detail-month;
                                font-size: Theme.ui-font-size - 1px; color: Theme.text-primary;
                                x: 8px; width: parent.width - 16px; height: parent.height; vertical-alignment: center;
                                input-type: number;
                                edited => {
                                    if self.text.character-count > 2 { self.text = root.detail-month; }
                                }
                            }
                        }
                        Text { text: "-"; color: Theme.text-muted; vertical-alignment: center; }
                        // Day
                        Rectangle {
                            width: 48px; border-radius: 6px;
                            background: Theme.bg-input; border-width: 1px; border-color: Theme.accent-dim;
                            if root.detail-day == "": Text { text: "DD"; font-size: Theme.ui-font-size - 2px; color: Theme.text-muted; x: 8px; vertical-alignment: center; }
                            TextInput {
                                text <=> root.detail-day;
                                font-size: Theme.ui-font-size - 1px; color: Theme.text-primary;
                                x: 8px; width: parent.width - 16px; height: parent.height; vertical-alignment: center;
                                input-type: number;
                                edited => {
                                    if self.text.character-count > 2 { self.text = root.detail-day; }
                                }
                            }
                        }
                    }
                    if !root.is-editing: Text {
                        text: (root.detail-year == "")
                            ? "—"
                            : (root.detail-year
                               + (root.detail-month == "" ? "" : "-" + root.detail-month)
                               + (root.detail-day == "" ? "" : "-" + root.detail-day));
                        font-size: Theme.ui-font-size;
                        color: root.detail-year == "" ? Theme.text-muted : Theme.text-primary;
                        vertical-alignment: center; height: 28px;
                    }
                }

                Rectangle { height: 14px; }
                Rectangle { height: 1px; background: Theme.border; }
                Rectangle { height: 12px; }

                // Details header (label always centered on its own row)
                SectionLabel { text: "DETAILS"; }

                // Template / add-field buttons on their own row (edit mode only)
                if root.is-editing: HorizontalLayout {
                    height: 26px; spacing: 4px; alignment: center;
                    load-tmpl-t := TouchArea {
                        width: 100px; height: 22px;
                        clicked => { root.show-template-picker = true; }
                        Rectangle {
                            border-radius: 5px;
                            background: load-tmpl-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                            border-width: 1px; border-color: Theme.border;
                            Text { text: "Load template"; font-size: max(9px, Theme.ui-font-size - 4px); color: Theme.text-secondary; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                    save-tmpl-t := TouchArea {
                        width: 108px; height: 22px;
                        clicked => {
                            root.name-input-title = "Save as template";
                            root.name-input-value = "";
                            root.name-input-purpose = "save-template";
                            root.show-name-input = true;
                        }
                        Rectangle {
                            border-radius: 5px;
                            background: save-tmpl-t.has-hover ? Theme.accent-dim : Theme.bg-surface;
                            border-width: 1px; border-color: Theme.border;
                            Text { text: "Save as template"; font-size: max(9px, Theme.ui-font-size - 4px); color: Theme.accent-text; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                    add-field-t := TouchArea {
                        width: 60px; height: 22px;
                        clicked => { root.add-custom-field(); }
                        Rectangle {
                            border-radius: 5px;
                            background: add-field-t.has-hover ? Theme.bg-elevated : Theme.bg-surface;
                            border-width: 1px; border-color: Theme.border;
                            Text { text: "+ Field"; font-size: max(9px, Theme.ui-font-size - 4px); color: Theme.text-secondary; horizontal-alignment: center; vertical-alignment: center; }
                        }
                    }
                }

                Rectangle { height: 8px; }

                // Custom fields (the whole panel scrolls via the outer ScrollView)
                VerticalLayout {
                    spacing: 10px; padding-right: 16px;

                        for f in root.detail-fields: VerticalLayout {
                            spacing: 3px;

                            // Field label row — absolute positions so Edit/× don't drift
                            Rectangle {
                                height: 22px;
                                if root.is-editing: TextInput {
                                    text: f.label;
                                    font-size: max(9px, Theme.ui-font-size - 4px);
                                    letter-spacing: 1.5px; font-weight: 600;
                                    font-family: Theme.content-font;
                                    color: Theme.text-muted;
                                    x: 0; width: parent.width - 90px; height: parent.height;
                                    vertical-alignment: center;
                                    edited => { root.custom-field-label-changed(f.id, self.text); }
                                }
                                if !root.is-editing: Text {
                                    text: f.label;
                                    font-size: max(9px, Theme.ui-font-size - 4px);
                                    letter-spacing: 1.5px; font-weight: 600; color: Theme.text-muted;
                                    font-family: Theme.content-font;
                                    x: 0; width: parent.width - 64px; height: parent.height;
                                    vertical-alignment: center;
                                }
                                // Edit button — fixed at right, leaving room for × in edit mode
                                edit-f-t := TouchArea {
                                    x: parent.width - (root.is-editing ? 82px : 56px); y: 0;
                                    width: 56px; height: 22px;
                                    clicked => {
                                        root.field-editor-title = f.label;
                                        root.field-editor-value = f.value;
                                        root.field-editor-purpose = f.id;
                                        root.show-field-editor = true;
                                    }
                                    Rectangle {
                                        border-radius: 4px;
                                        background: edit-f-t.has-hover ? Theme.bg-elevated : transparent;
                                        Text { text: "Enlarge"; font-size: max(9px, Theme.ui-font-size - 4px); color: Theme.text-secondary; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                                // Delete × — fixed at far right, edit mode only
                                if root.is-editing: del-f-t := TouchArea {
                                    x: parent.width - 22px; y: 0;
                                    width: 22px; height: 22px;
                                    clicked => { root.delete-custom-field(f.id); }
                                    Rectangle {
                                        border-radius: 4px;
                                        background: del-f-t.has-hover ? Theme.danger-bg : transparent;
                                        Text { text: "×"; font-size: 13px; font-weight: 400; color: Theme.danger-text; horizontal-alignment: center; vertical-alignment: center; }
                                    }
                                }
                            }

                            // Field value — themed multiline box, selectable in view mode
                            Rectangle {
                                height: f.label == "NOTES" ? 92px : 52px;
                                border-radius: 6px;
                                background: Theme.bg-input;
                                border-width: root.is-editing ? 1px : 0px;
                                border-color: Theme.accent-dim;
                                clip: true;
                                animate background { duration: 130ms; }
                                cf-focus-ta := TouchArea {
                                    width: parent.width; height: parent.height;
                                    enabled: root.is-editing;
                                    mouse-cursor: text;
                                    clicked => { cf-input.focus(); }
                                }
                                cf-input := TextInput {
                                    text: f.value;
                                    font-size: Theme.ui-font-size;
                                    font-family: Theme.content-font;
                                    color: f.value == "" && !root.is-editing ? Theme.text-muted : Theme.text-primary;
                                    x: 8px; y: 6px; width: parent.width - 14px; height: parent.height - 12px;
                                    wrap: word-wrap; single-line: false;
                                    read-only: !root.is-editing;
                                    edited => { root.custom-field-value-changed(f.id, self.text); }
                                }
                            }
                        }

                        Rectangle { height: 20px; }
                    }

                }
            }
        }
    }
    } // end FocusScope wrapper

    // ── Overlays (rendered on top) ─────────────────────────────────────────────

    if root.show-settings: SettingsPanel {
        width: root.width; height: root.height;
        close => { root.show-settings = false; fs.focus(); }
        toggle-dark-mode => { root.toggle-dark-mode(); }
        set-accent(c) => { root.set-accent(c); }
        set-font-size(s) => { root.set-font-size(s); }
        export-data => { root.export-data(); }
        import-data => { root.import-data(); }
        open-data-folder => { root.open-data-folder(); }
    }

    if root.show-icon-picker: IconPicker {
        width: root.width; height: root.height;
        close => { root.show-icon-picker = false; fs.focus(); }
        picked(ico) => { root.icon-picked(ico); root.show-icon-picker = false; fs.focus(); }
    }

    if root.show-template-picker: TemplatePicker {
        width: root.width; height: root.height;
        templates: root.templates;
        close => { root.show-template-picker = false; fs.focus(); }
        apply(id) => { root.apply-template(id); root.show-template-picker = false; fs.focus(); }
        delete-tmpl(id) => { root.delete-template(id); }
        rename-tmpl(id, name) => { root.rename-template(id, name); }
    }

    if root.show-lightbox: PhotoLightbox {
        width: root.width; height: root.height;
        photo: root.lightbox-photo;
        index: root.lightbox-index;
        count: root.lightbox-count;
        close => { root.show-lightbox = false; fs.focus(); }
        prev => {
            root.lightbox-index = root.lightbox-index <= 0 ? root.lightbox-count - 1 : root.lightbox-index - 1;
            root.lightbox-load(root.lightbox-index);
        }
        next => {
            root.lightbox-index = root.lightbox-index >= root.lightbox-count - 1 ? 0 : root.lightbox-index + 1;
            root.lightbox-load(root.lightbox-index);
        }
    }

    // Sort menu overlays (render above panels). Positioned under their bars.
    if root.coll-sort-open: TouchArea {
        width: root.width; height: root.height;
        clicked => { root.coll-sort-open = false; }
        SortMenu {
            x: 16px; y: 132px;
            width: root.left-width - 32px;
            mode: root.coll-sort-mode; is-collection: true;
            pick(m) => { root.coll-sort-mode = m; root.set-coll-sort(m); root.coll-sort-open = false; }
        }
    }
    if root.item-sort-open: TouchArea {
        width: root.width; height: root.height;
        clicked => { root.item-sort-open = false; }
        SortMenu {
            x: root.left-width + 16px; y: 134px;
            width: root.mid-width - 32px;
            mode: root.item-sort-mode; is-collection: false;
            pick(m) => { root.item-sort-mode = m; root.set-item-sort(m); root.item-sort-open = false; }
        }
    }

    // Context menu — collection
    if root.show-context-menu && root.ctx-is-collection: ContextMenu {
        width: root.width; height: root.height;
        menu-x: root.ctx-x; menu-y: root.ctx-y;
        show-rename: !root.ctx-multi;
        label-primary: root.ctx-multi ? "Duplicate all checked" : "Duplicate collection";
        label-danger:  root.ctx-multi ? "Delete all checked"    : "Delete collection";
        rename-action => {
            root.show-context-menu = false;
            root.name-input-title = "Rename collection";
            root.name-input-value = root.collections[root.ctx-target].name;
            root.name-input-purpose = "rename-coll";
            root.name-input-target = root.ctx-target;
            root.show-name-input = true;
        }
        primary-action => {
            root.show-context-menu = false;
            if root.ctx-multi { root.duplicate-selected-collections(); }
            else { root.duplicate-collection(root.ctx-target); }
        }
        danger-action => {
            root.show-context-menu = false;
            if root.ctx-multi { root.delete-selected-collections(); }
            else { root.delete-collection(root.ctx-target); }
        }
        dismissed => { root.show-context-menu = false; }
    }

    // Context menu — item
    if root.show-context-menu && !root.ctx-is-collection: ContextMenu {
        width: root.width; height: root.height;
        menu-x: root.ctx-x; menu-y: root.ctx-y;
        show-rename: !root.ctx-multi;
        label-primary: root.ctx-multi ? "Duplicate all checked" : "Duplicate item";
        label-danger:  root.ctx-multi ? "Delete all checked"    : "Delete item";
        rename-action => {
            root.show-context-menu = false;
            root.name-input-title = "Rename item";
            root.name-input-value = root.items[root.ctx-target].name;
            root.name-input-purpose = "rename-item";
            root.name-input-target = root.ctx-target;
            root.show-name-input = true;
        }
        primary-action => {
            root.show-context-menu = false;
            if root.ctx-multi { root.duplicate-selected-items(); }
            else { root.duplicate-item(root.ctx-target); }
        }
        danger-action => {
            root.show-context-menu = false;
            if root.ctx-multi { root.delete-selected-items(); }
            else { root.delete-item(root.ctx-target); }
        }
        dismissed => { root.show-context-menu = false; }
    }

    // Name input modal (rename collection/item, save template with name)
    if root.show-name-input: NameInputModal {
        width: root.width; height: root.height;
        title: root.name-input-title;
        value <=> root.name-input-value;
        close => { root.show-name-input = false; fs.focus(); }
        accepted(txt) => {
            root.show-name-input = false;
            if root.name-input-purpose == "rename-coll" {
                root.rename-collection(root.name-input-target, txt);
            } else if root.name-input-purpose == "rename-item" {
                root.rename-item(root.name-input-target, txt);
            } else if root.name-input-purpose == "save-template" {
                root.save-template-named(txt);
            }
            fs.focus();
        }
    }

    if root.show-field-editor: FieldEditorModal {
        width: root.width; height: root.height;
        title: root.field-editor-title;
        value <=> root.field-editor-value;
        word-count: root.field-editor-wordcount;
        word-limit: 200;
        init => { root.count-words(root.field-editor-value); }
        text-edited(txt) => { root.count-words(txt); }
        close => { root.show-field-editor = false; fs.focus(); }
        accepted(txt) => {
            root.show-field-editor = false;
            if root.field-editor-purpose == "desc" {
                root.detail-desc = txt;
                root.field-changed("desc", txt);
            } else {
                root.custom-field-value-changed(root.field-editor-purpose, txt);
            }
            fs.focus();
        }
    }
}
